---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Checkout & Pembayaran - Ballqish Shoes">
  <div class="bg-[#FAF9F6] min-h-screen py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header / Back Button -->
      <div class="mb-8 border-b border-gray-200 pb-4">
        <a href="/?openCart=true" class="inline-flex items-center text-xs font-heading font-semibold tracking-widest uppercase text-gray-500 hover:text-primary transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Kembali ke Keranjang
        </a>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- LEFT: Payment & Shipping Details -->
        <div class="flex-1 space-y-6">
          
          <!-- Informasi Pengiriman -->
          <div class="bg-white p-8 border border-gray-200">
            <h2 class="text-xs font-heading font-bold text-gray-900 mb-6 uppercase tracking-widest">
              Informasi Pengiriman
            </h2>
            <div class="space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-xs font-heading font-semibold text-gray-900 mb-2 uppercase tracking-wide">Nama Penerima</label>
                  <input type="text" id="cust-name" class="w-full border border-gray-300 px-4 py-3 text-sm font-body focus:outline-none focus:border-gray-900 bg-transparent transition-colors" placeholder="John Doe">
                </div>
                <div>
                  <label class="block text-xs font-heading font-semibold text-gray-900 mb-2 uppercase tracking-wide">Nomor Telepon (WA)</label>
                  <input type="tel" id="cust-phone" class="w-full border border-gray-300 px-4 py-3 text-sm font-body focus:outline-none focus:border-gray-900 bg-transparent transition-colors" placeholder="081234567890">
                </div>
              </div>
              <div>
                <label class="block text-xs font-heading font-semibold text-gray-900 mb-2 uppercase tracking-wide">Alamat Lengkap</label>
                <textarea id="cust-address" rows="3" class="w-full border border-gray-300 px-4 py-3 text-sm font-body focus:outline-none focus:border-gray-900 bg-transparent transition-colors" placeholder="Jl. Sudirman No. 123..."></textarea>
              </div>
            </div>
          </div>

          <!-- Metode Pembayaran -->
          <div class="bg-white p-8 border border-gray-200">
            <h2 class="text-xs font-heading font-bold text-gray-900 mb-6 uppercase tracking-widest">
              Metode Pembayaran
            </h2>
            
            <div class="space-y-3">
              <!-- E-Wallet -->
              <label class="payment-method border border-gray-200 p-4 flex items-center cursor-pointer hover:border-gray-900 transition-colors bg-white">
                <input type="radio" name="payment" value="ewallet" class="text-primary focus:ring-primary mr-4 w-4 h-4">
                <div class="flex-1">
                  <span class="font-heading font-semibold text-gray-900 block text-sm tracking-wide">E-Wallet</span>
                  <span class="text-xs text-gray-500 font-body">GoPay, OVO, DANA, ShopeePay</span>
                </div>
              </label>

              <!-- Bank Transfer -->
              <label class="payment-method border border-gray-200 p-4 flex items-center cursor-pointer hover:border-gray-900 transition-colors bg-white">
                <input type="radio" name="payment" value="bank" class="text-primary focus:ring-primary mr-4 w-4 h-4">
                <div class="flex-1">
                  <span class="font-heading font-semibold text-gray-900 block text-sm tracking-wide">Transfer Bank (Virtual Account)</span>
                  <span class="text-xs text-gray-500 font-body">BCA, Mandiri, BNI, BRI</span>
                </div>
              </label>

              <!-- QRIS -->
              <label class="payment-method border border-gray-200 p-4 flex items-center cursor-pointer hover:border-gray-900 transition-colors bg-white">
                <input type="radio" name="payment" value="qris" class="text-primary focus:ring-primary mr-4 w-4 h-4">
                <div class="flex-1">
                  <span class="font-heading font-semibold text-gray-900 block text-sm tracking-wide">QRIS</span>
                  <span class="text-xs text-gray-500 font-body">Scan dengan aplikasi M-Banking atau E-Wallet</span>
                </div>
              </label>
            </div>

            <!-- QRIS Dummy Display -->
            <div id="qris-display" class="hidden mt-6 p-6 border border-gray-300 text-center bg-[#FAF9F6]">
              <p class="text-xs font-heading font-semibold text-gray-900 uppercase tracking-widest mb-4">Scan kode QR (DUMMY)</p>
              <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=DUMMY_PAYMENT_QRIS_BALLQISH" alt="QRIS Dummy" class="mx-auto border border-gray-200 mix-blend-multiply">
              <p class="text-xs text-gray-500 mt-4">Peringatan: Ini hanya demonstrasi e-commerce.</p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Order Summary -->
        <div class="w-full lg:w-96 flex-shrink-0">
          <div class="bg-white p-8 border border-gray-200 sticky top-28">
            <h3 class="text-xs font-heading font-bold text-gray-900 uppercase tracking-widest mb-6">Ringkasan Pesanan</h3>
            
            <!-- Items Container -->
            <div id="checkout-items" class="space-y-4 mb-8 max-h-80 overflow-y-auto pr-2 hide-scrollbar">
              <!-- Diisi via JS -->
            </div>

            <!-- Voucher -->
            <div class="mb-8 pt-8 border-t border-gray-200">
              <label class="block text-xs font-heading font-semibold text-gray-900 mb-3 uppercase tracking-wide">Kode Voucher</label>
              <div class="flex">
                <input type="text" id="voucher-code" class="flex-1 border border-r-0 border-gray-300 px-4 py-3 text-sm font-body focus:outline-none focus:border-gray-900 bg-transparent uppercase transition-colors" placeholder="BQL2026">
                <button id="apply-voucher" class="bg-gray-900 text-white px-6 py-3 text-xs font-heading font-semibold uppercase tracking-widest hover:bg-primary transition-colors border border-gray-900 hover:border-primary">Apply</button>
              </div>
            </div>

            <!-- Totals -->
            <div class="space-y-4 pt-8 border-t border-gray-200 mb-8 font-body">
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Subtotal</span>
                <span id="summary-subtotal" class="font-bold text-gray-900">Rp 0</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Ongkos Kirim (Flat)</span>
                <span id="summary-shipping" class="font-bold text-gray-900">Rp 7.000</span>
              </div>
              <div id="discount-row" class="flex justify-between text-sm hidden text-gray-900">
                <span class="text-gray-500">Diskon</span>
                <span id="summary-discount" class="font-bold">- Rp 0</span>
              </div>
              <div class="flex justify-between items-center pt-4 mt-4 border-t border-gray-200">
                <span class="text-xs font-heading font-bold text-gray-900 uppercase tracking-widest">Total Tagihan</span>
                <span id="summary-total" class="text-xl font-heading font-bold text-gray-900">Rp 0</span>
              </div>
            </div>

            <button id="btn-pay-now" class="w-full bg-primary border border-primary text-white font-heading font-semibold text-xs uppercase tracking-widest px-4 py-4 hover:bg-gray-900 hover:border-gray-900 transition-colors flex justify-center items-center">
              Bayar Sekarang
            </button>
            <p class="text-[10px] text-gray-400 text-center mt-4 flex items-center justify-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              Pembayaran Anda aman dan terenkripsi.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    document.addEventListener('DOMContentLoaded', async () => {
      let cart = [];
      try {
        const c = localStorage.getItem('ballqish_cart');
        if (c) {
          cart = JSON.parse(c);
          cart = cart.filter((item: any) => item.id && item.id.length === 36);
          localStorage.setItem('ballqish_cart', JSON.stringify(cart));
        }
      } catch(e) {}

      if (cart.length === 0) {
        window.location.href = '/?openCart=true';
        return;
      }

      // Check Session & Pre-fill
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login';
        return;
      }

      const custName = document.getElementById('cust-name') as HTMLInputElement;
      if (custName && session.user.user_metadata?.full_name) {
        custName.value = session.user.user_metadata.full_name;
      }

      const shippingCost = 7000;
      let discountAmount = 0;
      let finalTotal = 0;

      function renderSummary() {
        const itemsContainer = document.getElementById('checkout-items');
        if (itemsContainer) {
          itemsContainer.innerHTML = cart.map((item: any) => `
            <div class="flex gap-4">
              <img src="${item.image}" class="w-16 h-16 object-cover mix-blend-multiply bg-gray-50 border border-gray-200" />
              <div class="flex-1">
                <p class="text-xs font-heading font-semibold text-gray-900 tracking-wide uppercase line-clamp-1">${item.name}</p>
                <p class="text-[11px] font-body text-gray-500 mt-1">Size ${item.size} • ${item.outsole || 'Model 1'}</p>
                <div class="flex justify-between items-center mt-2">
                  <span class="text-[13px] font-body font-bold text-gray-900">${item.quantity} x Rp ${item.price.toLocaleString('id-ID')}</span>
                </div>
              </div>
            </div>
          `).join('');
        }

        const subtotal = cart.reduce((sum: number, item: any) => sum + (item.price * item.quantity), 0);
        finalTotal = subtotal + shippingCost - discountAmount;

        const elSubtotal = document.getElementById('summary-subtotal');
        const elTotal = document.getElementById('summary-total');
        const elDiscount = document.getElementById('summary-discount');
        const rowDiscount = document.getElementById('discount-row');

        if (elSubtotal) elSubtotal.textContent = `Rp ${subtotal.toLocaleString('id-ID')}`;
        if (elTotal) elTotal.textContent = `Rp ${finalTotal.toLocaleString('id-ID')}`;
        
        if (discountAmount > 0 && elDiscount && rowDiscount) {
          elDiscount.textContent = `- Rp ${discountAmount.toLocaleString('id-ID')}`;
          rowDiscount.classList.remove('hidden');
        }
      }

      renderSummary();

      // Voucher Logic
      const btnApplyVoucher = document.getElementById('apply-voucher');
      btnApplyVoucher?.addEventListener('click', () => {
        const code = (document.getElementById('voucher-code') as HTMLInputElement).value.toUpperCase();
        if (code === 'DISKON20') {
          discountAmount = 20000;
          if (window.showToast) window.showToast('Voucher berhasil digunakan!', 'success');
        } else if (code) {
          discountAmount = 0;
          if (window.showToast) window.showToast('Voucher tidak valid atau sudah kadaluarsa', 'error');
        }
        renderSummary();
      });

      // Payment Method UI
      const paymentRadios = document.querySelectorAll('input[name="payment"]');
      const qrisDisplay = document.getElementById('qris-display');
      
      paymentRadios.forEach(radio => {
        radio.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          document.querySelectorAll('.payment-method').forEach(el => {
            el.classList.remove('border-red-600', 'bg-red-50');
            el.classList.add('border-gray-200');
          });
          
          if (target.checked) {
            target.closest('.payment-method')?.classList.add('border-gray-900', 'bg-[#FAF9F6]');
            target.closest('.payment-method')?.classList.remove('border-gray-200');
            
            if (target.value === 'qris' && qrisDisplay) {
              qrisDisplay.classList.remove('hidden');
            } else if (qrisDisplay) {
              qrisDisplay.classList.add('hidden');
            }
          }
        });
      });

      // Pay Now Logic
      const btnPayNow = document.getElementById('btn-pay-now');
      btnPayNow?.addEventListener('click', async () => {
        const selectedPayment = document.querySelector('input[name="payment"]:checked') as HTMLInputElement;
        
        const name = (document.getElementById('cust-name') as HTMLInputElement).value;
        const phone = (document.getElementById('cust-phone') as HTMLInputElement).value;
        const address = (document.getElementById('cust-address') as HTMLTextAreaElement).value;

        if (!name || !phone || !address) {
          if (window.showToast) window.showToast('Mohon lengkapi informasi pengiriman', 'error');
          return;
        }

        if (!selectedPayment) {
          if (window.showToast) window.showToast('Silakan pilih metode pembayaran', 'error');
          return;
        }

        // Simulate Loading
        const originalText = btnPayNow.innerHTML;
        btnPayNow.innerHTML = `<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Memproses...`;
        btnPayNow.setAttribute('disabled', 'true');

        try {
          // CREATE ORDER (Status: Diproses because it's a dummy paid transaction)
          const { data: order, error: orderError } = await supabase.from('orders').insert({
            user_id: session.user.id,
            customer_name: name,
            customer_phone: phone,
            customer_address: address,
            total_amount: finalTotal,
            status: 'Diproses'
          }).select().single();

          if (orderError) throw orderError;

          // Insert items
          const orderItems = cart.map((item: any) => ({
            order_id: order.id,
            product_id: item.id,
            product_name: item.name,
            product_image: item.image,
            size: item.size,
            outsole_model: item.outsole || 'Model 1',
            quantity: item.quantity,
            price: item.price
          }));

          const { error: itemsError } = await supabase.from('order_items').insert(orderItems);
          if (itemsError) throw itemsError;

          // Trigger Cloudflare Pages auto-build in background so E-Commerce static catalog updates
          fetch('https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/984ad6b4-c842-44cb-a50e-855dbfb7d6d4', { method: 'POST' }).catch(console.error);

          // SUCCESS
          localStorage.removeItem('ballqish_cart');
          window.location.href = '/?success=true';

        } catch (err: any) {
          console.error('Payment/Checkout Error:', err);
          if (window.showToast) window.showToast(`Gagal: ${err.message || 'Terjadi kesalahan'}`, 'error');
          btnPayNow.innerHTML = originalText;
          btnPayNow.removeAttribute('disabled');
        }
      });
    });
  </script>
</Layout>
